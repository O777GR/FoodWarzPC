
---

### 📄 `.gitignore`

```gitignore
# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# Виртуальное окружение
# ==========================================
venv/
ENV/
env/
.venv/

# ==========================================
# База данных
# ==========================================
*.db
*.sqlite
*.sqlite3
food_diary.db

# ==========================================
# Переменные окружения и секреты
# ==========================================
.env
.env.local
.env.*.local
*.env
secrets.toml
.streamlit/secrets.toml

# ==========================================
# IDE и редакторы
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ==========================================
# Streamlit
# ==========================================
.streamlit/
!.streamlit/config.toml

# ==========================================
# Логи и временные файлы
# ==========================================
*.log
logs/
tmp/
temp/
*.tmp

# ==========================================
# OS файлы
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==========================================
# llama.cpp и модели (если в проекте)
# ==========================================
llama.cpp/
*.gguf
*.bin
*.pt
*.pth
*.onnx
*.safetensors
models/
checkpoints/

# ==========================================
# Данные и кэш
# ==========================================
data/
cache/
*.cache
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==========================================
# Jupyter Notebook
# ==========================================
.ipynb_checkpoints
*.ipynb

# ==========================================
# Docker
# ==========================================
.dockerignore
docker-compose.yml
Dockerfile

# ==========================================
# CI/CD
# ==========================================
.github/
.gitlab-ci.yml

# ==========================================
# Документация (генерируемая)
# ==========================================
docs/_build/
site/

# ==========================================
# Специфичные для проекта
# ==========================================
# Если llama.cpp лежит рядом с проектом
../llama_cpp/
../AI_Servers/

# Тестовые данные
test_data/
*.csv
*.xlsx